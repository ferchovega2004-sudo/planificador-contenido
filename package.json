{
  "name": "planificador-contenido-root",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "api": "npm --prefix api run dev",
    "frontend": "npm --prefix frontend run dev",
    "dev": "concurrently \"npm run api\" \"npm run frontend\"",
    "install:all": "npm install --prefix api && npm install --prefix frontend",
    "build:frontend": "npm --prefix frontend run build"
  },
  "devDependencies": {
    "concurrently": "^9.2.3"
  }
}
